{
  "name": "n8n-nodes-google-speech",
  "version": "0.3.0",
  "description": "n8n node for Google Speech API integration",
  "keywords": [
    "n8n-community-node-package",
    "google-speech",
    "speech-to-text",
    "text-to-speech"
  ],
  "license": "MIT",
  "homepage": "https://github.com/ziobuddalabs/n8n-google-speech",
  "author": {
    "name": "ZioBudda Labs",
    "email": "info@ziobuddalabs.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ziobuddalabs/n8n-google-speech.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc --skipLibCheck && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier --write .",
    "lint": "eslint nodes credentials"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/GoogleSpeechApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/GoogleSpeech/GoogleSpeech.node.js"
    ]
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/luxon": "^3.4.2",
    "@types/node": "^18.16.3",
    "@types/request": "^2.48.12",
    "@types/request-promise-native": "^1.0.21",
    "@typescript-eslint/eslint-plugin": "^5.59.2",
    "@typescript-eslint/parser": "^5.59.2",
    "eslint": "^8.40.0",
    "eslint-plugin-n8n-nodes-base": "^1.13.1",
    "gulp": "^4.0.2",
    "n8n-core": "^0.161.0",
    "n8n-workflow": "^0.146.0",
    "prettier": "^2.8.8",
    "typescript": "~4.9.5"
  },
  "dependencies": {
    "@google-cloud/speech": "^5.4.0",
    "@google-cloud/text-to-speech": "^4.2.2"
  }
}
